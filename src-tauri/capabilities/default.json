{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set granted to the main LensLM window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "core:window:allow-start-dragging",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    }
  ]
}
