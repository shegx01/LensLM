{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LensLM",
  "version": "0.1.0",
  "identifier": "com.lenslm.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "LensLM",
        "label": "main",
        "create": false,
        "width": 1024,
        "height": 1024,
        "minWidth": 725,
        "minHeight": 725,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 30 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'sha256-EPB8q+R7chM/2GDPSkscM53/b8eDLk1hpO3spvSAMng='; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../sidecar/qwen3-tts/qwen3_tts_sidecar.py",
      "../sidecar/qwen3-tts/pyproject.toml",
      "../sidecar/qwen3-tts/uv.lock"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": ["frameworks/libpdfium.dylib"]
    }
  }
}
