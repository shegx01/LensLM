    "@testing-library/svelte": "^5.4.0",
    "@types/node": "^26.0.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
